# Portal2 Environment Configuration Template
# Copy this file to .env and .env.local and fill in appropriate values
# .env.local will override values in .env for local development

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Port for the main application server
SERVER_PORT=3000


# Node.js environment (development, production, test)
NODE_ENV=development

# =============================================================================
# URL CONFIGURATION
# =============================================================================
# Base URL for the user interface
UI_BASE_URL=http://localhost:3000

# Base URL for API endpoints
API_BASE_URL=http://localhost:3000/api

# WebSocket base URL for real-time communication
WS_BASE_URL=ws://localhost:3001

# =============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# =============================================================================
# PostgreSQL database host
DB_HOST=localhost

# PostgreSQL database port
DB_PORT=5432

# Database name
DB_NAME=portal

# Database username (REQUIRED)
DB_USER=

# Database password (REQUIRED)  
DB_PASSWORD=

# Session table name
DB_SESSION_TABLE=session

# Enable database query logging (true/false)
DB_LOGGING=false

# =============================================================================
# SESSION CONFIGURATION (REQUIRED)
# =============================================================================
# Secret key for session signing (REQUIRED - use a strong random string)
SESSION_SECRET=

# Session TTL in seconds (default: 86400 = 1 day)
SESSION_TTL=86400

# Use secure cookies (true for HTTPS, false for HTTP)
SESSION_SECURE_COOKIE=false

# =============================================================================
# AUTHENTICATION CONFIGURATION (REQUIRED)
# =============================================================================
# Keycloak realm name (REQUIRED)
KEYCLOAK_REALM=

# Keycloak authentication server URL (REQUIRED)
KEYCLOAK_AUTH_URL=

# Keycloak client ID (REQUIRED)
KEYCLOAK_CLIENT=

# Keycloak client secret (REQUIRED)
KEYCLOAK_SECRET=

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# HMAC key for token generation
HMAC_KEY=

# Honeypot field encoding divisor (anti-spam)
HONEYPOT_DIVISOR=7

# UID number offset for user creation
UID_NUMBER_OFFSET=2831

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Terrain API URL for DE integration
TERRAIN_URL=

# Terrain API username
TERRAIN_USER=

# Terrain API password
TERRAIN_PASSWORD=

# Portal Conductor URL for user/service workflows
PORTAL_CONDUCTOR_URL=

# =============================================================================
# LDAP CONFIGURATION (Optional)
# =============================================================================
LDAP_HOST=
LDAP_ADMIN=
LDAP_PASSWORD=
LDAP_BASE_DN=
LDAP_EVERYONE_GROUP=

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# SMTP server configuration
SMTP_FROM=support@cyverse.org
SMTP_HOST=localhost
SMTP_PORT=

# Support email address
SUPPORT_EMAIL=support@cyverse.org

# BCC recipients for various email types
BCC_NEW_ACCOUNT_CONFIRMATION=
BCC_PASSWORD_CHANGE_REQUEST=
BCC_SERVICE_ACCESS_GRANTED=
BCC_WORKSHOP_ENROLLMENT_REQUEST=

# =============================================================================
# INTERCOM INTEGRATION (Optional)
# =============================================================================
# Enable Intercom chat widget (true/false)
INTERCOM_ENABLED=false

# Intercom application ID
INTERCOM_APP_ID=

# Intercom access token
INTERCOM_TOKEN=

# Intercom company ID
INTERCOM_COMPANY_ID=

# Intercom admin/bot IDs for automatic assignment
INTERCOM_ADMIN_USER_PORTAL_BOT_ID=
INTERCOM_ADMIN_TIER1_ATMOSPHERE_ID=
INTERCOM_ADMIN_TIER1_SCIENCE_TEAM_ID=
INTERCOM_ADMIN_TIER1_DATA_WATCH_ID=

# =============================================================================
# MAILING LIST INTEGRATION (Optional)
# =============================================================================
# Enable Mailman integration (true/false)
MAILMAN_ENABLED=false
MAILMAN_URL=
MAILMAN_PASSWORD=

# Enable MailChimp integration (true/false)  
MAILCHIMP_ENABLED=false
MAILCHIMP_URL=
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_TAGS=

# =============================================================================
# MONITORING & ANALYTICS (Optional)
# =============================================================================
# Google Analytics tracking ID
GOOGLE_ANALYTICS_ID=

# Sentry error tracking DSN
SENTRY_DSN=

# =============================================================================
# USER PROFILE SETTINGS
# =============================================================================
# Days after which profile update is required
PROFILE_UPDATE_PERIOD=365

# Days before requirement when warning is shown
PROFILE_WARNING_PERIOD=30

# Text shown for profile update requirement
PROFILE_UPDATE_TEXT=Please update your profile information

# Text shown for profile update warning
PROFILE_WARNING_TEXT=Your profile information will need to be updated soon

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================
# Username to emulate in development (bypasses auth)
DEBUG_USER=

# Native workflow Docker image ID
NATIVE_WORKFLOW_IMAGE_ID=

# =============================================================================
# EXTERNAL LINKS
# =============================================================================
# FAQ/Help documentation URL
FAQ_URL=

# Tour/Tutorial URL
TOUR_URL=https://learning.cyverse.org/mooc/