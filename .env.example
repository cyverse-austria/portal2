# Portal2 Production/Staging Environment Example
# This file shows example values for a production-like setup
# Copy to .env and customize for your environment

# =============================================================================
# SERVER CONFIGURATION  
# =============================================================================
SERVER_PORT=3000
NODE_ENV=production

# =============================================================================
# URL CONFIGURATION
# =============================================================================
UI_BASE_URL=https://portal.example.org
API_BASE_URL=https://portal.example.org/api  
WS_BASE_URL=wss://portal.example.org:3001

# =============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# =============================================================================
DB_HOST=postgres.example.org
DB_PORT=5432
DB_NAME=portal_prod
DB_USER=portal_user
DB_PASSWORD=your_secure_database_password_here
DB_SESSION_TABLE=session
DB_LOGGING=false

# =============================================================================
# SESSION CONFIGURATION (REQUIRED)
# =============================================================================
SESSION_SECRET=your_very_long_and_secure_session_secret_here_at_least_32_characters
SESSION_TTL=86400
SESSION_SECURE_COOKIE=true

# =============================================================================
# AUTHENTICATION CONFIGURATION (REQUIRED)
# =============================================================================
KEYCLOAK_REALM=CyVerse
KEYCLOAK_AUTH_URL=https://auth.example.org/auth/
KEYCLOAK_CLIENT=portal-client
KEYCLOAK_SECRET=your-keycloak-client-secret

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
HMAC_KEY=your_secure_hmac_key_for_token_generation
HONEYPOT_DIVISOR=7
UID_NUMBER_OFFSET=2831

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
TERRAIN_URL=https://de.cyverse.org/terrain
TERRAIN_USER=portal_service_account
TERRAIN_PASSWORD=terrain_service_password
PORTAL_CONDUCTOR_URL=https://conductor.example.org

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
SMTP_FROM=support@example.org
SMTP_HOST=smtp.example.org
SMTP_PORT=587
SUPPORT_EMAIL=support@example.org
BCC_NEW_ACCOUNT_CONFIRMATION=admin@example.org
BCC_PASSWORD_CHANGE_REQUEST=admin@example.org
BCC_SERVICE_ACCESS_GRANTED=admin@example.org
BCC_WORKSHOP_ENROLLMENT_REQUEST=admin@example.org

# =============================================================================
# INTERCOM INTEGRATION
# =============================================================================
INTERCOM_ENABLED=true
INTERCOM_APP_ID=your_intercom_app_id
INTERCOM_TOKEN=your_intercom_access_token
INTERCOM_COMPANY_ID=your_intercom_company_id
INTERCOM_ADMIN_USER_PORTAL_BOT_ID=bot_id_123
INTERCOM_ADMIN_TIER1_ATMOSPHERE_ID=admin_id_456
INTERCOM_ADMIN_TIER1_SCIENCE_TEAM_ID=team_id_789
INTERCOM_ADMIN_TIER1_DATA_WATCH_ID=watch_id_012

# =============================================================================
# MAILING LIST INTEGRATION
# =============================================================================
MAILMAN_ENABLED=true
MAILMAN_URL=https://maillist.example.org:443
MAILMAN_PASSWORD=mailman_admin_password

MAILCHIMP_ENABLED=false
MAILCHIMP_URL=
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_TAGS=

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX-X
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# USER PROFILE SETTINGS
# =============================================================================
PROFILE_UPDATE_PERIOD=365
PROFILE_WARNING_PERIOD=30
PROFILE_UPDATE_TEXT=Please update your profile to continue using the portal
PROFILE_WARNING_TEXT=Your profile information needs to be updated soon

# =============================================================================
# EXTERNAL LINKS
# =============================================================================
FAQ_URL=https://learning.cyverse.org/faq/
TOUR_URL=https://learning.cyverse.org/mooc/